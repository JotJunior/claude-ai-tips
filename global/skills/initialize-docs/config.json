{
  "$schema": "https://json-schema.org/draft-07/schema",
  "_comment": "Configuracao por projeto para a skill initialize-docs. Quando ausente, usa defaults (estrutura 01-09).",
  "docs_dir": "docs",
  "structure": [
    { "path": "01-briefing-discovery", "description": "Documentos iniciais, briefings, requisitos de negocio" },
    { "path": "02-requisitos-casos-uso", "description": "Casos de uso detalhados (UC-*)" },
    { "path": "03-modelagem-dados", "description": "Modelagem de dados, DERs, schemas" },
    { "path": "04-arquitetura-sistema", "description": "Decisoes de arquitetura (ADR-*), diagramas" },
    { "path": "05-definicao-apis", "description": "Contratos de API (REST, gRPC, Webhooks, Messaging)" },
    { "path": "05-definicao-apis/REST", "description": "APIs REST" },
    { "path": "05-definicao-apis/gRPC", "description": "Definicoes gRPC/protobuf" },
    { "path": "05-definicao-apis/WEBHOOKS", "description": "Webhooks" },
    { "path": "05-definicao-apis/MESSAGING", "description": "Mensageria (RabbitMQ, Kafka, etc)" },
    { "path": "06-ui-ux-design", "description": "Wireframes, mockups, guias de estilo" },
    { "path": "07-plano-testes", "description": "Planos e casos de teste" },
    { "path": "08-operacoes", "description": "Runbooks, procedimentos operacionais" },
    { "path": "09-entregaveis", "description": "Release notes, documentos de entrega" }
  ],
  "keep_in_root": ["tasks-*.md", "tasks.md", "cronograma*.md", "README.md"],
  "file_routing": {
    "UC-*.md": "02-requisitos-casos-uso/",
    "DER-*.md": "03-modelagem-dados/",
    "SCHEMA-*.md": "03-modelagem-dados/",
    "ADR-*.md": "04-arquitetura-sistema/",
    "*-api.md": "05-definicao-apis/REST/",
    "*.proto.md": "05-definicao-apis/gRPC/",
    "TC-*.md": "07-plano-testes/",
    "TP-*.md": "07-plano-testes/",
    "RB-*.md": "08-operacoes/",
    "RUNBOOK-*.md": "08-operacoes/",
    "RELEASE-*.md": "09-entregaveis/",
    "CHANGELOG*.md": "09-entregaveis/",
    "BRIEFING-*.md": "01-briefing-discovery/"
  }
}
